# RBS type signature file
# NOTE: Do not include private method definitions in RBS files.
#       Only public interfaces should be documented here.

module Factorix
  class Config
    attr_reader log_level: Symbol
    attr_reader runtime: Runtime
    attr_reader rcon: RCon
    attr_reader http: HTTP
    attr_reader cache: Cache

    def self.default: () -> Config

    def self.load_file: (Pathname path) -> Config

    def self.from_h: (Hash[Symbol, untyped] hash) -> Config

    class Runtime
      attr_reader executable_path: Pathname?
      attr_reader user_dir: Pathname?
      attr_reader data_dir: Pathname?
    end

    class RCon
      attr_reader host: String
      attr_reader port: Integer
      attr_reader password: String?
    end

    class HTTP
      attr_reader connect_timeout: Integer
      attr_reader read_timeout: Integer
      attr_reader write_timeout: Integer
    end

    class Cache
      attr_reader download: CacheType
      attr_reader api: CacheType
      attr_reader info_json: CacheType

      def to_h: () -> Hash[Symbol, CacheType]
    end

    class CacheType
      attr_reader backend: Symbol
      attr_reader ttl: Integer?
      attr_reader file_system: FileSystemBackend
      attr_reader redis: RedisBackend
      attr_reader s3: S3Backend

      def to_h: () -> Hash[Symbol, untyped]
    end

    class FileSystemBackend
      attr_reader max_file_size: Integer?
      attr_reader compression_threshold: Integer?

      def to_h: () -> Hash[Symbol, untyped]
    end

    class RedisBackend
      attr_reader url: String?
      attr_reader lock_timeout: Integer

      def to_h: () -> Hash[Symbol, untyped]
    end

    class S3Backend
      attr_reader bucket: String?
      attr_reader region: String?
      attr_reader lock_timeout: Integer

      def to_h: () -> Hash[Symbol, untyped]
    end

    class LegacyConverter
      def self.convert: (Pathname path) -> String

      def convert: (Pathname path) -> String
    end
  end
end
